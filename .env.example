# ============================================================
# EXAI INTELLIGENCE — environment variables
# Copy this file to .env and fill in real values.
# .env itself must NEVER be committed to git (see .gitignore).
# ============================================================

# ---- Groq (AI analysis) ----
# Get a fresh key at https://console.groq.com/keys
# IMPORTANT: the key that was in the original n8n export is
# considered compromised — it must be revoked in the Groq console
# and replaced with a brand new one here.
GROQ_API_KEY=

# ---- Gmail (sending the briefing) — OAuth2, same method n8n used ----
# Create OAuth2 credentials in Google Cloud Console:
#   APIs & Services > Credentials > Create Credentials > OAuth client ID
#   Application type: Desktop app
# Then use the included `npm run gmail-auth` helper once locally to
# generate a refresh token (see README for the one-time steps).
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=
GMAIL_SENDER_NAME=EXAI Intelligence
GMAIL_REPLY_TO=

# ---- Google Sheets (subscriber list + Exai Indicators / actuals) ----
# Service Account — no browser login needed, works headless on Railway.
# 1. Google Cloud Console > IAM & Admin > Service Accounts > Create
# 2. Create a JSON key for it, download it
# 3. Share BOTH Google Sheets (subscriber list + Exai Indicators) with
#    the service account's email address (Viewer is enough for Indicators,
#    Viewer is enough for subscriber list too since we only read)
# 4. Paste the values from the downloaded JSON below
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Spreadsheet IDs (from the sheet URLs)
SUBSCRIBERS_SHEET_ID=1RNw4OLdqzLvAa1vJGaN7KbEvdLEGvE-Pnp3LQEw8Ucg
SUBSCRIBERS_SHEET_TAB=Sheet1

INDICATORS_SHEET_ID=1Fvz2GBXyKELncOvyBQTTVpUojxreXjhR0nrAMVqMA48
INDICATORS_SHEET_TAB=Sheet1

# ---- Schedule ----
# Cron expression, same as the original n8n trigger (05:00 and 14:00 WAT, Mon–Fri)
CRON_SCHEDULE=0 5,14 * * 1-5
TIMEZONE=Africa/Lagos
