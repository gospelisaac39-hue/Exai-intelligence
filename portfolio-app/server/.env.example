# ============================================================
# EXAI PORTFOLIO INTELLIGENCE — server environment variables
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# ---- Server ----
PORT=4000
FRONTEND_URL=http://localhost:5173

# ---- Auth ----
# Any long random string. Rotate it and every existing login session
# is invalidated (all JWTs signed with the old secret stop verifying).
JWT_SECRET=

# ---- SQLite ----
# Path is relative to portfolio-app/server. Default is fine for local dev.
DATABASE_PATH=./data/portfolio.sqlite

# ---- MetaApi.cloud ----
# Create an account at https://app.metaapi.cloud and generate a token
# under API access. This token lets the server provision and stream
# MT4/MT5 accounts on the user's behalf — treat it like a secret.
METAAPI_TOKEN=

# ---- Groq (AI Insights) ----
# Reuses the same key type as the root pipeline's GROQ_API_KEY —
# get one at https://console.groq.com/keys. Can be the same key as
# the root .env or a separate one; either works.
GROQ_API_KEY=
